# ─────────────────────────────────────────────
# Anthropic
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# Google OAuth2  (create at console.cloud.google.com)
# Enable: Search Console API + Google Analytics Data API
# Scopes needed:
#   https://www.googleapis.com/auth/webmasters.readonly
#   https://www.googleapis.com/auth/analytics.readonly
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...    # run `node generate-token.js` once to get this

# ─────────────────────────────────────────────
# Site identifiers
# ─────────────────────────────────────────────
# GSC site URL — use "sc-domain:naukridhaba.in" (domain property)
# OR "https://naukridhaba.in/" (URL-prefix property)
GSC_SITE_URL=sc-domain:naukridhaba.in

# GA4 property ID — numeric, e.g. 123456789 (not UA-...)
GA4_PROPERTY_ID=

# ─────────────────────────────────────────────
# Repo root (absolute path)
# ─────────────────────────────────────────────
REPO_ROOT=/home/user/naukri-dhaba
